{
    "debuggerType": "emmylua_gmod",
    "protocolVersion": "gmod-1",
    "capabilities": {
        "supportsSetVariable": true,
        "supportsSetExpression": false,
        "supportTerminateDebuggee": false,
        "supportsLogPoints": false
    },
    "unsupportedRationale": {
        "setExpression": "LRDB protocol has no assignment/eval-set request.",
        "terminateDebuggee": "Adapter can only disconnect its transport and helper process, not terminate the Garry's Mod runtime.",
        "logpoints": "LRDB add_breakpoint does not accept log message payloads."
    },
    "mandatoryParityScenarios": [
        "initializeCapabilities",
        "setExpressionUnsupported",
        "terminateDebuggeeUnsupported",
        "logpointUnsupported",
        "setVariableRoundTrip"
    ],
    "dapMappings": {
        "setBreakpoints": {
            "request": "add_breakpoint",
            "fields": ["file", "line", "condition", "hit_condition"]
        },
        "continue": "continue",
        "pause": "pause",
        "pauseSoft": "pause",
        "pauseNow": "pause_now",
        "resume": "continue",
        "next": "step",
        "stepIn": "step_in",
        "stepOut": "step_out",
        "stackTrace": "get_stacktrace",
        "locals": "get_local_variable",
        "upvalues": "get_upvalues",
        "globals": "get_global",
        "evaluate": "eval",
        "runCommand": "command"
    }
}
