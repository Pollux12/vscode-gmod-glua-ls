{
    "if": {
        "prefix": "if",
        "body": [
            "if ${1:condition} then",
            "\t$0",
            "end"
        ],
        "description": "If block"
    },
    "if-else": {
        "prefix": "ife",
        "body": [
            "if ${1:condition} then",
            "\t${2}",
            "else",
            "\t$0",
            "end"
        ],
        "description": "If/else block"
    },
    "for-range": {
        "prefix": "for",
        "body": [
            "for ${1:i} = ${2:1}, ${3:10} do",
            "\t$0",
            "end"
        ],
        "description": "Numeric for loop"
    },
    "for-in": {
        "prefix": "forin",
        "body": [
            "for ${1:k}, ${2:v} in ${3:pairs(${4:tbl})} do",
            "\t$0",
            "end"
        ],
        "description": "Generic for loop"
    },
    "while": {
        "prefix": "while",
        "body": [
            "while ${1:condition} do",
            "\t$0",
            "end"
        ],
        "description": "While loop"
    },
    "repeat-until": {
        "prefix": "repeat",
        "body": [
            "repeat",
            "\t$0",
            "until ${1:condition}"
        ],
        "description": "Repeat/until loop"
    },
    "do-block": {
        "prefix": "do",
        "body": [
            "do",
            "\t$0",
            "end"
        ],
        "description": "Do/end block"
    },
    "function": {
        "prefix": "fun",
        "body": [
            "function ${1:name}(${2})",
            "\t$0",
            "end"
        ],
        "description": "Function definition"
    },
    "local-function": {
        "prefix": "lfun",
        "body": [
            "local function ${1:name}(${2})",
            "\t$0",
            "end"
        ],
        "description": "Local function definition"
    },
    "function-assignment": {
        "prefix": "f=",
        "body": [
            "${1:name} = function(${2})",
            "\t$0",
            "end"
        ],
        "description": "Assign anonymous function"
    }
}
