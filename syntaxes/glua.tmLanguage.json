{
    "name": "GLua Injection",
    "scopeName": "gluals.lua.injection",
    "injectionSelector": "L:source.lua -comment -string",
    "patterns": [
        {
            "include": "#doc-comments"
        },
        {
            "include": "#c-style-comments"
        },
        {
            "include": "#continue-keyword"
        },
        {
            "include": "#c-style-operators"
        },
        {
            "include": "#gmod-constants"
        }
    ],
    "repository": {
        "c-style-comments": {
            "patterns": [
                {
                    "begin": "/\\*",
                    "beginCaptures": {
                        "0": {
                            "name": "punctuation.definition.comment.lua"
                        }
                    },
                    "end": "\\*/",
                    "name": "comment.block.lua"
                },
                {
                    "captures": {
                        "1": {
                            "name": "punctuation.definition.comment.lua"
                        }
                    },
                    "match": "(//)(?!\\[\\[).*$",
                    "name": "comment.line.double-slash.lua"
                }
            ]
        },
        "c-style-operators": {
            "patterns": [
                {
                    "match": "\\|\\||&&|!=",
                    "name": "keyword.operator.lua"
                }
            ]
        },
        "continue-keyword": {
            "patterns": [
                {
                    "match": "\\b(continue|not)\\b",
                    "name": "keyword.control.lua"
                }
            ]
        },
        "doc-comments": {
            "patterns": [
                {
                    "match": "(---\\s*)(@param)\\s+([A-Za-z_][A-Za-z0-9_]*)(?:\\s+([^#\\r\\n]+))?",
                    "captures": {
                        "1": {
                            "name": "comment.line.documentation.lua"
                        },
                        "2": {
                            "name": "storage.type.annotation.lua"
                        },
                        "3": {
                            "name": "variable.parameter.function.lua"
                        },
                        "4": {
                            "name": "support.type.lua"
                        }
                    }
                },
                {
                    "match": "(---\\s*)(@field)\\s+([A-Za-z_][A-Za-z0-9_]*)(?:\\s+([^#\\r\\n]+))?",
                    "captures": {
                        "1": {
                            "name": "comment.line.documentation.lua"
                        },
                        "2": {
                            "name": "storage.type.annotation.lua"
                        },
                        "3": {
                            "name": "entity.other.attribute.lua"
                        },
                        "4": {
                            "name": "support.type.lua"
                        }
                    }
                },
                {
                    "match": "(---\\s*)(@(?:alias|as|async|attribute|cast|class|deprecated|diagnostic|enum|export|generic|hook|interface|mapping|meta|module|namespace|nodiscard|operator|overload|realm|return|returncast|see|source|type|using|version|readonly))\\b(?:\\s+([^#\\r\\n]+))?",
                    "captures": {
                        "1": {
                            "name": "comment.line.documentation.lua"
                        },
                        "2": {
                            "name": "storage.type.annotation.lua"
                        },
                        "3": {
                            "name": "support.type.lua"
                        }
                    }
                },
                {
                    "match": "---.*$",
                    "name": "comment.line.documentation.lua"
                }
            ]
        },
        "gmod-constants": {
            "patterns": [
                {
                    "match": "\\b(?:CLIENT|SERVER|GAMEMODE|EFFECT|GM|SWEP|TOOL|ENT|SANDBOX)\\b",
                    "name": "constant.language.lua"
                }
            ]
        }
    },
    "uuid": "6f3998ab-6d0d-4db0-a780-4f370cab14c6"
}
